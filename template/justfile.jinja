# List available recipes
default:
    @just --list
{% if ci_github %}

# Set up branch protection and GitHub Pages (run once after pushing to GitHub)
init-remote:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! command -v gh &>/dev/null || ! gh auth status &>/dev/null 2>&1; then
        echo "gh CLI not found or not authenticated — set up branch protection and GitHub Pages manually"
        exit 0
    fi
    REPO=$(git remote get-url origin 2>/dev/null | sed 's|.*github.com[:/]||;s|\.git$||')
    BP_JSON=$(mktemp)
    cat > "$BP_JSON" <<'BPEOF'
    {
      "required_status_checks": {
        "strict": true,
        "contexts": ["lint",{% if use_typecheck %} "type-check",{% endif %} "test (3.11)", "test (3.12)", "test (3.13)"{% if security != 'none' %}, "audit"{% endif %}]
      },
      "enforce_admins": false,
      "required_pull_request_reviews": null,
      "restrictions": null,
      "allow_force_pushes": false,
      "allow_deletions": false
    }
    BPEOF
    if gh api "repos/${REPO}/branches/main/protection" -X PUT --silent --input "$BP_JSON" 2>/dev/null; then
        echo "✓ Branch protection enabled on main"
    else
        echo "⚠ Could not set branch protection (check gh auth permissions)"
    fi
    rm -f "$BP_JSON"
{%- if use_docs %}
    if gh api "repos/${REPO}/pages" -X POST -f build_type=workflow --silent 2>/dev/null; then
        echo "✓ GitHub Pages enabled (Actions source)"
    else
        echo "⚠ Could not enable GitHub Pages (may already be enabled, or enable manually in Settings > Pages)"
    fi
{%- endif %}
{% endif %}

# Install dependencies and set up dev environment
setup:
    git config core.longpaths true
    uv sync --dev
{%- if security != 'none' %}
    uv run pre-commit install
{%- endif %}

# Run all checks (mirrors CI)
check: lint{% if use_typecheck %} typecheck{% endif %} test

# Lint and check formatting
lint:
    uv run ruff check src/ tests/
    uv run ruff format --check src/ tests/

# Auto-fix lint and formatting issues
fix:
    uv run ruff check --fix src/ tests/
    uv run ruff format src/ tests/
{% if use_typecheck %}

# Type check
typecheck:
    uv run mypy src/
{% endif %}

# Run tests
test *args:
    uv run pytest -v {% raw %}{{ args }}{% endraw %}
{% if testing != 'minimal' %}

# Run tests with coverage{% if testing == 'full' %} (fails if below 80%){% endif %}

coverage:
    uv run pytest --cov=src --cov-report=term-missing{% if testing == 'full' %} --cov-fail-under=80{% endif %}

{% endif %}
{% if use_ml %}

# Launch Jupyter notebook server
notebook:
    uv run jupyter notebook notebooks/
{% endif %}
{% if use_docs %}

# Serve documentation locally
docs:
    uv run mkdocs serve

# Build documentation
docs-build:
    uv run mkdocs build
{% endif %}
{% if use_docker != 'none' %}

# Build Docker image
docker-build:
    docker compose -f docker/docker-compose.yml build

# Run in Docker
docker-run:
    docker compose -f docker/docker-compose.yml up
{% endif %}
{% if use_docker == 'gpu' %}

# Build GPU Docker image
docker-build-gpu:
    docker build -f docker/Dockerfile.gpu -t {{ project_name }}-gpu .
{% endif %}
{% if security != 'none' %}

# Audit dependencies for vulnerabilities
audit:
    uv run pip-audit
{% endif %}

# Build package
build:
    uv build

# Bump version, create git tag, and push (usage: just release patch|minor|major)
release bump:
    #!/usr/bin/env bash
    set -euo pipefail
    just check
    uvx bump-my-version bump {% raw %}{{ bump }}{% endraw %}
    git push --follow-tags
{% if use_ml %}

# Initialize DVC (run once)
dvc-init:
    uv run dvc init
    uv run dvc config core.autostage true
{% endif %}

# Clean build artifacts
clean:
    rm -rf dist/ build/{% if use_docs %} site/{% endif %} .pytest_cache/{% if use_typecheck %} .mypy_cache/{% endif %} .ruff_cache/ htmlcov/
    find . -type d -name __pycache__ -exec rm -rf {} +
