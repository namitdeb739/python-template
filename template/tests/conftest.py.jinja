@pytest.fixture
def mock_serial() -> Generator[MagicMock, None, None]:
    """Mock serial.Serial so serial tests run without hardware attached."""
    from unittest.mock import patch

    with patch("serial.Serial") as mock_cls:
        instance = mock_cls.return_value.__enter__.return_value = mock_cls.return_value
        instance.readline.return_value = b"OK\r\n"
        instance.read.return_value = b"\x00"
        instance.write.return_value = 4
        instance.is_open = True
        yield instance


@pytest.fixture(autouse=True)
def mock_gpio() -> Generator[None, None, None]:
    """Replace gpiozero pin factory with MockFactory for all tests.

    This means GPIO tests run in CI without any physical hardware.
    To test with real hardware, remove this fixture or override it locally.
    """
    try:
        from gpiozero import Device
        from gpiozero.pins.mock import MockFactory

        original = Device.pin_factory
        Device.pin_factory = MockFactory()
        yield
        Device.pin_factory = original
    except ImportError:
        yield  # gpiozero not installed; skip silently
